# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code (settings + nested git worktrees)
.claude/

# local data dumps (client exports — never commit PII)
*.xlsx

# local debug/probe scripts — never commit (may contain credentials/PII)
/scratch/
/scratch_*.js
/read_*.js
*.png

# MicroSIP call recordings (PII — customer audio, synced to CRM storage instead)
/Record call/
*.mp3
*.wav
.snapshots/

# local transcription test assets (audio + scratch json/txt — never commit, kept local)
/test-audio/

# python bytecode (recorder/ + etl/ pipelines)
__pycache__/
*.pyc
